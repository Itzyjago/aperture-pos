{
  "name": "aperture-pos",
  "private": true,
  "version": "1.0.0",
  "description": "Aperture POS — Aperture Commerce Cloud: enterprise point-of-sale & retail-operations platform for multi-store chains.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
